# GoHighLevel API credentials
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Open Permits data source (Socrata/SODA endpoint)
# Default: City of Austin open data portal
PERMITS_API_URL=https://data.austintexas.gov/resource/3syk-w9eu.json
PERMITS_APP_TOKEN=your_socrata_app_token_here

# Scoring thresholds
MIN_LEAD_SCORE=50

# Pipeline settings
PERMITS_LIMIT=200
